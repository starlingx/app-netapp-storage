#!/usr/bin/make -f

export DEB_VERSION = $(shell dpkg-parsechangelog | egrep '^Version:' | cut -f 2 -d ' ')
export PATCH_VERSION = $(shell echo $(DEB_VERSION) | cut -f 4 -d '.')
export CHART_BASE_VERSION = $(shell echo $(DEB_VERSION) | sed 's/-/./' | cut -d '.' -f 1-3)
export CHART_VERSION = $(CHART_BASE_VERSION)+STX.$(PATCH_VERSION)

export ROOT = debian/tmp
export APP_FOLDER = $(ROOT)/usr/lib/helm

%:
	dh $@

override_dh_auto_build:
	mkdir -p charts
	cp -r helm/trident-operator charts/netapp-trident
	sed -i 's/^name: trident-operator/name: netapp-trident/' charts/netapp-trident/Chart.yaml
	cp Makefile charts/
	cd charts && make CHART_VERSION=$(CHART_VERSION) netapp-trident

override_dh_auto_install:
	install -d -m 755 $(APP_FOLDER)
	install -p -D -m 644 charts/netapp-trident*.tgz $(APP_FOLDER)

override_dh_auto_test:
